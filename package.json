{
  "name": "@andypf/json-viewer",
  "version": "2.7.2",
  "description": "A javascript library to visualize json nicely",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "keywords": [
    "react-json",
    "react-json-tree",
    "json-react",
    "json",
    "browser",
    "pretty",
